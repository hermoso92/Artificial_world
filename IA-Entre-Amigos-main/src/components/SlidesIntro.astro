  <h1 class="cover-title">IA entre amigos</h1>
  <p class="cover-subtitle">Para profesionales de la ingenieria</p>
  <p class="cover-meta">Marzo 2026</p>
  <p class="cover-repo">
    <a href="https://github.com/686f6c61/IA-Entre-Amigos" target="_blank" rel="noopener noreferrer">
      <i data-lucide="github"></i> github.com/686f6c61/IA-Entre-Amigos
    </a>
  </p>
  <p class="cover-repo">
    <a href="https://drive.proton.me/urls/2QKERRWCDM#y6KKvymTcq13" target="_blank" rel="noopener noreferrer">
