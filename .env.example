# Constructor de Mundos — Variables de entorno (plantilla)
# Copia a .env y rellena con tus valores. NUNCA commitear .env
#
# Crear: copy .env.example .env  (Windows)
#        cp .env.example .env    (Linux/Mac)

# === Puertos (por defecto: 3001 backend, 5173 frontend — ver scripts/iniciar_fullstack.ps1) ===
# PORT=3001
# VITE_BACKEND_PORT=3001
# VITE_FRONTEND_PORT=5173

# === CORS (producción) ===
# Orígenes permitidos separados por coma. Vacío = permitir todos (desarrollo)
# ALLOWED_ORIGINS=https://tudominio.com,https://app.tudominio.com

# === Stripe ===
# Obtén las keys en https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Admin (modo dios) — solo estos player_id pueden acceder a /api/admin/* ===
# ADMIN_PLAYER_IDS=player_xxx,player_yyy
# ADMIN_SECRET=tu_secreto_opcional  # Si se define, exige header x-admin-secret en cada request admin

# === DobackSoft (cupón fundadores) ===
FUNDADOR_COUPON=MUNDOFUNDADOR500

# === Hostinger VPS / Deploy ===
# SSH_HOST=tu-ip-o-dominio.com
# SSH_USER=root
