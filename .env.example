# artificial word - Variables de entorno (plantilla)
# Copia a .env y rellena con tus valores. NUNCA commitear .env
#
# Crear: cp .env.example .env  (Linux/Mac)
#        copy .env.example .env  (Windows)

# === API Keys (para futuras integraciones) ===
# OpenAI Enterprise / API
# OPENAI_API_KEY=sk-...
#
# Cursor API (si expones endpoints propios)
# CURSOR_API_KEY=...

# === Hostinger VPS / Deploy ===
# SSH_HOST=tu-ip-o-dominio.com
# SSH_USER=root
# SSH_KEY_PATH=~/.ssh/id_rsa
# REMOTE_PATH=/var/www/html/artificialword

# === Base URL (cuando tengas dominio) ===
# BASE_URL=https://artificialword.tudominio.com

# === DobackSoft (cupón fundadores) ===
# DOBACKSOFT_COUPON_CODE=FUNDADOR1000
