# Constructor de Mundos — Variables de entorno (plantilla)
# Copia a .env y rellena con tus valores. NUNCA commitear .env
#
# Crear: copy .env.example .env  (Windows)
#        cp .env.example .env    (Linux/Mac)

# === Puertos (por defecto: 3001 backend, 5173 frontend — ver scripts/iniciar_fullstack.ps1) ===
# PORT=3001
# VITE_BACKEND_PORT=3001
# VITE_FRONTEND_PORT=5173

# === CORS (producción) ===
# OBLIGATORIO en producción — el servidor falla al iniciar si NODE_ENV=production y no está definido.
# Orígenes permitidos separados por coma. Vacío = permitir todos (solo desarrollo)
# ALLOWED_ORIGINS=https://tudominio.com,https://app.tudominio.com

# === Mission Control (OpenClaw local-first) ===
# seed     = runtime local persistente con eventos realistas y adapter hibrido
# disabled = desactiva el runtime seed para conectar luego un gateway real
# MISSION_CONTROL_RUNTIME_MODE=seed
# MISSION_CONTROL_TICK_MS=4000
# OPENCLAW_GATEWAY_URLS=ws://localhost:18789
# OPENCLAW_GATEWAY_TOKEN=  # Se envía por header Authorization: Bearer (no en URL)
# OPENCLAW_GATEWAY_SCOPES=operator.read,operator.approvals
# OPENCLAW_GATEWAY_ROLE=operator
# OPENCLAW_GATEWAY_CLIENT_ID=mission-control
# OPENCLAW_GATEWAY_CLIENT_VERSION=0.1.0

# === Stripe ===
# Obtén las keys en https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Admin (modo dios) — solo estos player_id pueden acceder a /api/admin/* ===
# ADMIN_PLAYER_IDS=player_xxx,player_yyy
# ADMIN_SECRET=tu_secreto_opcional  # Si se define, exige header x-admin-secret en cada request admin

# === DobackSoft (cupón fundadores) ===
FUNDADOR_COUPON=MUNDOFUNDADOR500

# === Hostinger VPS / Deploy ===
# SSH_HOST=tu-ip-o-dominio.com
# SSH_USER=root
