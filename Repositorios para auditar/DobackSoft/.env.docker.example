# Docker - Ejemplo de entorno (Dev y Prod/Comercial)
# Copiar a .env y rellenar valores. No commitear .env.
# Elegir UNO: Dev (backend/frontend en local) o Prod (todo en Docker).

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-en-produccion
POSTGRES_DB=dobacksoft

# --- Dev: backend y frontend en local con iniciar.ps1; db y redis en Docker ---
# DATABASE_URL y REDIS_URL con localhost (conexión desde tu máquina al contenedor).
DATABASE_URL=postgresql://postgres:cambiar-en-produccion@localhost:5432/dobacksoft
REDIS_URL=redis://localhost:6379

# --- Prod (VPS): stack completo en Docker (docker compose up -d) ---
# En producción el backend ya recibe DATABASE_URL y REDIS_URL por docker-compose.
# Si quieres definirlos en .env: descomenta y pon la misma POSTGRES_PASSWORD de arriba.
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db:5432/dobacksoft
# REDIS_URL=redis://redis:6379

# JWT y CORS (obligatorios en producción)
JWT_SECRET=cambiar-jwt-secret-en-produccion
JWT_REFRESH_SECRET=cambiar-jwt-refresh-secret-en-produccion
# En VPS usar la URL pública del frontend (ej. https://srv844849.hstgr.cloud o http://IP:5174)
CORS_ORIGIN=http://localhost

# Backend
NODE_ENV=production
PORT=9998

# Datos FTP/ingesta (host Ubuntu)
# DATA_DIR debe apuntar a la carpeta de organización (CMadrid)
# Usa rutas absolutas (sin barra final)
DATA_DIR=/home/doback/datosDoback/CMadrid
# Carpeta base de ingesta automática (sin /CMadrid)
INGESTION_DATA_FOLDER=/home/doback/datosDoback
# Ruta real en el host que se montará dentro del contenedor backend
DATOS_DOBACK_HOST_PATH=/home/doback/datosDoback
# Ruta destino dentro del contenedor (dejar por defecto salvo necesidad)
DATOS_DOBACK_CONTAINER_PATH=/home/doback/datosDoback

# Opcionales (en VPS conviene definir FRONTEND_URL con la URL pública)
LOG_LEVEL=info
# En VPS: misma URL que CORS_ORIGIN (ej. https://srv844849.hstgr.cloud)
FRONTEND_URL=http://localhost
