DATABASE_URL=postgresql://postgres:cosigein@localhost:5432/dobacksoft

# Ingesta: carpeta base para subida masiva (opcional; por defecto backend/data/datosDoback).
# Subcarpetas por org: CMadrid, demo, Formacion. Estructura: carpeta/(CMadrid|demo|Formacion)/vehiculo/archivos
# INGESTION_DATA_FOLDER=backend/data/datosDoback
# URL de la API backend
VITE_API_URL=http://localhost:9998

# URL del WebSocket 
VITE_WS_URL=ws://localhost:9998/ws

# Entorno de ejecución
VITE_APP_ENV=development

# Otras configuraciones
VITE_APP_NAME=SDOBACK SOFT
VITE_APP_VERSION=2.0
VITE_APP_DESCRIPTION=Sistema de Monitoreo de Estabilidad de Vehículos

# Tiempo de refresco de datos (en milisegundos)
VITE_REFRESH_INTERVAL=5000

# Opciones de desarrollo
VITE_ENABLE_MOCKS=false
VITE_DEBUG_MODE=true

# Valhalla map-matching (docs/valhalla-setup.md). Mejora precisión de límites de velocidad.
# VALHALLA_URL=http://localhost:8002
# ENABLE_VALHALLA_MAP_MATCHING=false
# DEBUG_VALHALLA=false
# OSM_GRAPH_VERSION=2026-02  # Cambiar al reimportar OSM/tiles para invalidar cache

# Training: login por identifier sin RFID (solo dev). Backend: monta /api/training/auth/dev-login
TRAINING_DEV_LOGIN=true
# Training: muestra botón "Modo pruebas" en Kiosk (frontend)
VITE_TRAINING_DEV_LOGIN=true
# Training: segundos aproximados por violación de velocidad (duración estimada; default 5)
# TRAINING_SPEED_VIOLATION_AVG_SECONDS=5