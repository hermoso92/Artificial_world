    "Nombre del guardado": {},
    "Nueva partida": {},
    "Nuevo guardado": {},
    "Nutrientes": {},
    "Partidas en el dispositivo": {},
    "Personalidad": {},
    "Pide confirmación antes de borrar el archivo.": {},
    "Posición": {},
    "Quizá fue removido al cargar otra partida.": {},
